# Auto detect text files and perform LF normalization
* text=auto

# Source code files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Configuration files
*.config.js text eol=lf
*.config.ts text eol=lf
package.json text eol=lf
package-lock.json text eol=lf
tsconfig.json text eol=lf
tailwind.config.js text eol=lf
vite.config.ts text eol=lf
postcss.config.js text eol=lf

# SQL files
*.sql text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary

# Archive files
*.zip binary
*.tar binary
*.gz binary
*.rar binary
*.7z binary

# Executable files
*.exe binary
*.dll binary
*.so binary
*.dylib binary

# Documentation
README.md text eol=lf
DEPLOYMENT.md text eol=lf
*.md text eol=lf

# Environment files
.env* text eol=lf
env.example text eol=lf

# Git files
.gitignore text eol=lf
.gitattributes text eol=lf
