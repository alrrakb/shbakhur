{
    "name": "orders-management-system",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
        "lint:fix": "eslint . --ext ts,tsx --fix",
        "preview": "vite preview",
        "type-check": "tsc --noEmit",
        "clean": "rm -rf dist node_modules/.vite",
        "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
        "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
        "analyze": "npm run build && npx vite-bundle-analyzer dist/assets/*.js",
        "test": "echo \"No tests specified\" && exit 0",
        "test:watch": "echo \"No tests specified\" && exit 0",
        "prepare": "husky install || true"
    },
    "dependencies": {
        "@hookform/resolvers": "^3.3.2",
        "@supabase/supabase-js": "^2.38.4",
        "@tanstack/react-query": "^5.8.4",
        "@types/jsbarcode": "^3.11.4",
        "@types/qrcode": "^1.5.5",
        "date-fns": "^2.30.0",
        "html2canvas": "^1.4.1",
        "jsbarcode": "^3.12.1",
        "jspdf": "^2.5.2",
        "lucide-react": "^0.294.0",
        "qrcode": "^1.5.4",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-hook-form": "^7.48.2",
        "react-hot-toast": "^2.4.1",
        "react-router-dom": "^6.20.1",
        "react-to-print": "^2.14.15",
        "zod": "^3.22.4"
    },
    "keywords": [
        "orders",
        "management",
        "system",
        "react",
        "typescript",
        "supabase",
        "ecommerce",
        "inventory",
        "invoices",
        "arabic"
    ],
    "author": {
        "name": "نظام إدارة الطلبات",
        "email": "support@orders-system.com"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/your-username/orders-management-system.git"
    },
    "bugs": {
        "url": "https://github.com/your-username/orders-management-system/issues"
    },
    "homepage": "https://github.com/your-username/orders-management-system#readme",
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=8.0.0"
    },
    "devDependencies": {
        "@types/react": "^18.2.37",
        "@types/react-dom": "^18.2.15",
        "@typescript-eslint/eslint-plugin": "^6.10.0",
        "@typescript-eslint/parser": "^6.10.0",
        "@vitejs/plugin-react": "^4.1.1",
        "autoprefixer": "^10.4.16",
        "eslint": "^8.53.0",
        "eslint-plugin-react-hooks": "^4.6.0",
        "eslint-plugin-react-refresh": "^0.4.4",
        "postcss": "^8.4.31",
        "tailwindcss": "^3.3.5",
        "typescript": "^5.2.2",
        "vite": "^4.5.0"
    }
}